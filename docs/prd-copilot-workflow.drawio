        <mxCell id="title" value="PRD Copilot 用户主流程" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="60" y="40" width="360" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="从自然语言需求输入到文档、流程图、质量检查和历史记录的完整闭环。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#4B5563;" vertex="1" parent="1">
          <mxGeometry x="60" y="78" width="640" height="24" as="geometry" />
        </mxCell>
        <mxCell id="n1" value="1. 输入需求&#xa;一句需求或一段需求描述" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;strokeColor=#1F2937;fillColor=#F3F4F6;fontSize=14;fontColor=#111827;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="180" width="200" height="96" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="2. AI 拆解结构&#xa;名称、用户、痛点、目标、模块、页面" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;strokeColor=#312E81;fillColor=#E0E7FF;fontSize=14;fontColor=#111827;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="320" y="180" width="220" height="96" as="geometry" />
        </mxCell>
        <mxCell id="n3" value="3. 用户确认调整&#xa;补缺失项、删无关项、改字段" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;strokeColor=#1F2937;fillColor=#F9FAFB;fontSize=14;fontColor=#111827;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="600" y="180" width="220" height="96" as="geometry" />
        </mxCell>
        <mxCell id="n4" value="4. 生成产品文档&#xa;固定输出 8 个模块" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;strokeColor=#1F2937;fillColor=#F3F4F6;fontSize=14;fontColor=#111827;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="880" y="180" width="220" height="96" as="geometry" />
        </mxCell>
        <mxCell id="n5" value="5. 优化与改写&#xa;正式 / 简洁 / PRD / 汇报" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;strokeColor=#1F2937;fillColor=#F9FAFB;fontSize=14;fontColor=#111827;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="1160" y="180" width="220" height="96" as="geometry" />
        </mxCell>
        <mxCell id="n6" value="6. 导出流程图&#xa;节点连线 JSON -> drawio XML" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;strokeColor=#065F46;fillColor=#D1FAE5;fontSize=14;fontColor=#111827;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="1440" y="180" width="220" height="96" as="geometry" />
        </mxCell>
        <mxCell id="n7" value="7. 质量检查与协作视图&#xa;检查缺失项，生成研发视图和测试视图" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;strokeColor=#92400E;fillColor=#FEF3C7;fontSize=14;fontColor=#111827;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="880" y="350" width="260" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n8" value="8. 历史记录&#xa;保存输入、文档版本、流程图版本" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;strokeColor=#1F2937;fillColor=#F3F4F6;fontSize=14;fontColor=#111827;spacing=14;" vertex="1" parent="1">
